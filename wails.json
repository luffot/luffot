  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "luffot-settings",
  "outputfilename": "Luffot Settings",
  "frontend": {
    "dir": "./frontend",
    "install": "npm install",
    "build": "npm run build && mkdir -p internal/assets/frontend/dist && cp -r frontend/dist/* internal/assets/frontend/dist/",
